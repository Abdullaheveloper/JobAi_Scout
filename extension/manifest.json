{
  "manifest_version": 3,
  "name": "Job Form Fill",
  "version": "4.3.0",
  "description": "Evidence-led job application assistance with safe profile filling and applicant review.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.ashbyhq.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.jobvite.com/*",
    "https://*.icims.com/*",
    "https://apply.workable.com/*",
    "https://www.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://docs.google.com/forms/*",
    "https://uhvjleclbpseveyeajap.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Form Fill"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.ashbyhq.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.jobvite.com/*",
        "https://*.icims.com/*",
        "https://apply.workable.com/*",
        "https://www.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://docs.google.com/forms/*"
      ],
      "js": [
        "decision-engine.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
