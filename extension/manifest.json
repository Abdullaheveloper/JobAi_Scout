{
  "manifest_version": 3,
  "name": "JobAI Scout - Job Discovery & Auto-Fill",
  "version": "2.0.0",
  "description": "Discover jobs from LinkedIn, Indeed, Glassdoor & more. AI-matched recommendations synced to JobAI. Auto-fills applications with your profile.",
  "permissions": ["activeTab", "storage", "scripting", "identity", "notifications"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobAI Scout"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
